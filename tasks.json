{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build ImGui SDL2 App",
      "type": "shell",
      "command": "C:/msys64/ucrt64/bin/g++.exe",
      "args": [
        "-std=c++17",

        "src/main.cpp",
        "src/Product.cpp",  
        "src/Storage.cpp",  
        "src/Machine.cpp",  
        "src/Factory.cpp",
        "src/UI_Core.cpp",
        "src/UI_Scenes.cpp",
        "src/frontend.cpp",

        "libs/imgui/imgui.cpp",
        "libs/imgui/imgui_draw.cpp",
        "libs/imgui/imgui_tables.cpp",
        "libs/imgui/imgui_widgets.cpp",
        "libs/imgui/backends/imgui_impl_sdl2.cpp",
        "libs/imgui/backends/imgui_impl_opengl3.cpp",

        "-Ilibs/imgui",
        "-Ilibs/imgui/backends",
        "-IC:/msys64/ucrt64/include/SDL2",

        "-LC:/msys64/ucrt64/lib",
        "-lmingw32",
        "-lSDL2main",
        "-lSDL2",
        "-lopengl32",

        "-mwindows",
        "-o",
        "build/app.exe"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "C:\\msys64\\ucrt64\\bin;C:\\msys64\\usr\\bin;${env:PATH}"
        }
      }
    }
  ]
}